{
  "name": "@ntnkit/sdk",
  "version": "0.1.0",
  "description": "NTN-aware client SDK with outbox and pluggable transports",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "author": "Hossein Yavari",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hyavari/ntnkit.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/hyavari/ntnkit#readme",
  "bugs": {
    "url": "https://github.com/hyavari/ntnkit/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@ntnkit/core": "workspace:*"
  }
}
