{
  "name": "@ntnkit/sqlite",
  "version": "0.1.1",
  "description": "SQLite durable outbox and runtime state for ntnkit (Node)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "author": "Hossein Yavari",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hyavari/ntnkit.git",
    "directory": "packages/sqlite"
  },
  "homepage": "https://github.com/hyavari/ntnkit/tree/master/packages/sqlite#readme",
  "bugs": {
    "url": "https://github.com/hyavari/ntnkit/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@ntnkit/core": "workspace:*",
    "@ntnkit/sdk": "workspace:*",
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13"
  }
}
