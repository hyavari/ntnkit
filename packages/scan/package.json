{
  "name": "@ntnkit/scan",
  "version": "0.1.1",
  "description": "NTN readiness scanner and conformance checks",
  "type": "module",
  "bin": {
    "ntnkit-scan": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "author": "Hossein Yavari",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hyavari/ntnkit.git",
    "directory": "packages/scan"
  },
  "homepage": "https://github.com/hyavari/ntnkit/tree/master/packages/scan#readme",
  "bugs": {
    "url": "https://github.com/hyavari/ntnkit/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@ntnkit/core": "workspace:*"
  }
}
