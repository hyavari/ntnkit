{
  "name": "@ntnkit/scan",
  "version": "0.0.1",
  "description": "NTN readiness scanner and conformance checks",
  "type": "module",
  "bin": {
    "ntnkit-scan": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@ntnkit/core": "workspace:*"
  }
}
